# ─────────────────────────────────────────────
#  Polymarket BTC Bot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Your Polygon wallet private key (hex, no 0x prefix needed)
# KEEP THIS SECRET — never commit .env to git
PRIVATE_KEY=your_polygon_wallet_private_key_here

# Your Polygon wallet address (the public address, safe to share)
WALLET_ADDRESS=0xYourWalletAddressHere

# Optional: Override starting capital tracking (in USDC)
INITIAL_CAPITAL=300
